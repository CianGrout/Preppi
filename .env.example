# Convex (set after running `npx convex dev`)
CONVEX_DEPLOYMENT=dev:your-deployment-name

# Expo / app (EXPO_PUBLIC_* are embedded at build time)
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Native Google sign-in client IDs
EXPO_PUBLIC_GOOGLE_SERVER_CLIENT_ID=your-google-server-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
