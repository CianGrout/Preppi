{
  "expo": {
    "scheme": "prepiapp",
    "plugins": [
      "expo-audio",
      "expo-asset",
      "expo-camera",
      "expo-secure-store",
      "expo-font",
      "expo-image",
      "expo-router",
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
        "iosUrlScheme": "com.googleusercontent.apps.580560219338-dc8jh46e1h69ha4euplnog9tp28issj3"        }
      ]
    ],
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.cian.prepiapp.v1"
    },
    "ios": {
      "bundleIdentifier": "com.cian.prepiapp.v1"
    }
  }
}